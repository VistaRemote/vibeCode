{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "extends": ["./biome.json"],
  "files": {
    "includes": [
      "**",
      "!**/*.md",
      "!**/node_modules",
      "!**/android",
      "!**/ios",
      "!**/coverage"
    ]
  },
  "javascript": {
    "jsxRuntime": "reactClassic"
  },
  "overrides": [
    {
      "includes": ["**/*.tsx", "**/*.jsx"],
      "linter": {
        "rules": {
          "correctness": {
            "useExhaustiveDependencies": "warn"
          }
        }
      }
    }
  ]
}
