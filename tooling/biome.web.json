{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "extends": ["./biome.frontend.json"],
  "files": {
    "includes": [
      "**",
      "!**/*.md",
      "!**/*.mdx",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/.rsbuild"
    ]
  },
  "javascript": {
    "jsxRuntime": "reactClassic"
  },
  "overrides": [
    {
      "includes": ["**/*.tsx", "**/*.jsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useButtonType": "warn"
          },
          "correctness": {
            "useExhaustiveDependencies": "warn"
          }
        }
      }
    },
    {
      "includes": ["**/*.scss"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false }
    }
  ]
}
