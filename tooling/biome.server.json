{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "extends": ["./biome.backend.json"],
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/*.md",
      "!**/node_modules",
      "!**/dist",
      "!**/coverage",
      "!**/migrations/**/*.js"
    ]
  },
  "overrides": [
    {
      "includes": ["**/*.spec.ts", "**/*.e2e-spec.ts", "test/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}
